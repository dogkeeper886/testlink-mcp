id: TC-S2-003
name: "MCP Tool: create_test_case"
suite: s2-test-case
priority: 1
timeout: 30000
dependencies: [TC-S1-001]

steps:
  - name: "Create a test case via MCP"
    command: |
      RESULT=$(npx tsx cicd/tests/src/mcp-client.ts create_test_case \
        '{"data":{"testprojectid":"162","testsuiteid":"163","name":"CI-Created-Case","authorlogin":"admin","summary":"Created by TC-TOOL-001","importance":2}}' \
        2>/dev/null)
      echo "$RESULT"
      # Extract test case ID from nested JSON response
      TC_ID=$(echo "$RESULT" | python3 -c "import sys,json; r=json.load(sys.stdin); d=json.loads(r['content'][0]['text']); print(d[0]['id'])")
      echo "CREATED_TC_ID=$TC_ID"
      echo "$TC_ID" > /tmp/tc-tool-001-id.txt
    timeout: 15000
    expectPatterns:
      - "CREATED_TC_ID="
      - "createTestCase"

  - name: "Verify created test case is readable"
    command: |
      TC_ID=$(cat /tmp/tc-tool-001-id.txt)
      RESULT=$(npx tsx cicd/tests/src/mcp-client.ts read_test_case \
        "{\"test_case_id\":\"$TC_ID\"}" \
        2>/dev/null)
      echo "$RESULT"
      TEXT=$(echo "$RESULT" | python3 -c "import sys,json; r=json.load(sys.stdin); print(r['content'][0]['text'])")
      echo "$TEXT" | grep -q "CI-Created-Case" && echo "VERIFY_OK"
    timeout: 15000
    expectPatterns:
      - "CI-Created-Case"
      - "VERIFY_OK"

criteria: |
  Verify that:
  - create_test_case creates a test case in TestLink project testlink-mcp (id:162)
  - The created test case can be read back and matches the input data

goal: "Test the create_test_case MCP tool against real TestLink"
