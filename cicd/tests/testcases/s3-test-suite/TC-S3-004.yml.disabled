id: TC-S3-004
name: "MCP Tool: create_test_suite"
suite: s3-test-suite
priority: 6
timeout: 30000
dependencies: [TC-S1-001]

steps:
  - name: "Create a top-level suite"
    command: |
      STAMP=$(date +%s)
      SUITE_NAME="CI-Suite-$STAMP"
      echo "$SUITE_NAME" > /tmp/tc-tool-006-name.txt
      RESULT=$(npx tsx cicd/tests/src/mcp-client.ts create_test_suite \
        "{\"project_id\":\"162\",\"suite_name\":\"$SUITE_NAME\",\"details\":\"Created by TC-TOOL-006\"}" \
        2>/dev/null)
      echo "$RESULT"
      TEXT=$(echo "$RESULT" | python3 -c "import sys,json; r=json.load(sys.stdin); print(r['content'][0]['text'])")
      SUITE_ID=$(echo "$TEXT" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d[0].get('id','') if isinstance(d,list) else d.get('id',''))")
      echo "CREATED_SUITE_ID=$SUITE_ID"
      echo "$SUITE_ID" > /tmp/tc-tool-006-suite-id.txt
    timeout: 15000
    expectPatterns:
      - "CREATED_SUITE_ID="

  - name: "Create a nested child suite"
    command: |
      PARENT_ID=$(cat /tmp/tc-tool-006-suite-id.txt)
      STAMP=$(date +%s)
      CHILD_NAME="CI-Child-$STAMP"
      RESULT=$(npx tsx cicd/tests/src/mcp-client.ts create_test_suite \
        "{\"project_id\":\"162\",\"suite_name\":\"$CHILD_NAME\",\"details\":\"Child suite\",\"parent_id\":\"$PARENT_ID\"}" \
        2>/dev/null)
      echo "$RESULT"
      TEXT=$(echo "$RESULT" | python3 -c "import sys,json; r=json.load(sys.stdin); print(r['content'][0]['text'])")
      CHILD_ID=$(echo "$TEXT" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d[0].get('id','') if isinstance(d,list) else d.get('id',''))")
      echo "CREATED_CHILD_ID=$CHILD_ID"
    timeout: 15000
    expectPatterns:
      - "CREATED_CHILD_ID="

  - name: "Verify created suite appears in listing"
    command: |
      SUITE_NAME=$(cat /tmp/tc-tool-006-name.txt)
      RESULT=$(npx tsx cicd/tests/src/mcp-client.ts list_test_suites \
        '{"project_id":"162"}' \
        2>/dev/null)
      echo "$RESULT"
      TEXT=$(echo "$RESULT" | python3 -c "import sys,json; r=json.load(sys.stdin); print(r['content'][0]['text'])")
      echo "$TEXT" | grep -q "$SUITE_NAME" && echo "VERIFY_SUITE_OK"
    timeout: 15000
    expectPatterns:
      - "VERIFY_SUITE_OK"

criteria: |
  Verify that:
  - create_test_suite creates a top-level suite in project 162
  - create_test_suite creates a nested suite with parent_id
  - The created suite appears in list_test_suites output

goal: "Test the create_test_suite MCP tool with top-level and nested suites"
