      echo "DISABLED: no create_requirement tool to provision a fixture"
    expectPatterns:
      - "DISABLED"

criteria: |
  get_requirement returns a requirement — blocked on a creatable fixture.
goal: "Read a requirement via the MCP get_requirement tool"
