TESTLINK_URL=http://192.168.4.114/testlink
TESTLINK_API_KEY=your_testlink_api_key_here

# Agent judge (for test framework) — opt-in second opinion, off by default
JUDGE_MODE=simple
# JUDGE_AGENT: command that launches the ACP agent. Unset → the bundled Claude
# ACP agent, keyless via ~/.claude (local) or CLAUDE_CODE_OAUTH_TOKEN (CI).
# Set it to another ACP agent's command to swap models/vendors — config, not code.
# JUDGE_AGENT=